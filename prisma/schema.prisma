// CaseCompass AI — application authorization & domain data.
//
// Clerk is the system of record for authentication (sessions, password
// hashing/verification, login). This schema is the system of record for
// AUTHORIZATION (role, institution/facility scope, account status,
// mustChangePassword) and product data. No password or password hash is
// ever stored here — see docs/behavior/authentication-behavior.md.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// Prisma 7: connection URLs live in prisma.config.ts (for Migrate) and are
// passed to the driver adapter at runtime (see lib/db.ts) — not here.
datasource db {
  provider = "postgresql"
}

enum UserRole {
  INDIVIDUAL
  INCARCERATED_USER
  EDUCATOR
  LEGAL_AID_STAFF
  INSTITUTION_ADMIN
  SYSTEM_ADMIN
}

enum AccountStatus {
  ACTIVE
  DISABLED
  LOCKED
  PENDING_FIRST_LOGIN
  TEMPORARY_PASSWORD_EXPIRED
  /// Soft-hidden from the active roster — distinct from DISABLED (a
  /// temporary block); an archived account is treated as permanently
  /// retired but its history is preserved, never deleted.
  ARCHIVED
}

/// Kept open-ended (OTHER + institutionTypeOther freeform label on
/// Institution) so new institution categories — law schools, nonprofits,
/// educational partners — never require an enum migration to add.
enum InstitutionType {
  STATE_PRISON
  FEDERAL_PRISON
  COUNTY_JAIL
  REENTRY_PROGRAM
  LAW_LIBRARY
  LEGAL_AID_PARTNER
  EDUCATIONAL_PARTNER
  OTHER
}

enum IntakeStatus {
  DRAFT
  INTERVIEWING
  NEEDS_CLARIFICATION
  READY_FOR_REVIEW
  COMPLETED
  ABANDONED
}

enum MatterStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum RoadmapSourceKind {
  AI_GENERATED
  DETERMINISTIC_FALLBACK
}

enum AuditOutcome {
  SUCCESS
  FAILURE
}

enum RoadmapStepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum SavedResourceType {
  RESOURCE
  LEGAL_TERM
  ROADMAP_STEP
  SOURCE
  NOTE
}

/// Safe, UI-facing activity events — never security audit events (see
/// AuditLog) and never full narrative text. See
/// lib/activity/approved-activity-events.ts for the allowlist this enum
/// must stay in sync with.
enum UserActivityType {
  INTAKE_STARTED
  INTAKE_ANSWER_UPDATED
  INTAKE_REVIEW_OPENED
  INTAKE_CONFIRMED
  ROADMAP_GENERATED
  ROADMAP_STEP_STARTED
  ROADMAP_STEP_COMPLETED
  RESOURCE_VIEWED
  LEGAL_TERM_SEARCHED
  NOTE_SAVED
  RESOURCE_SAVED
  CASE_SAVED
}

model Institution {
  id     String  @id @default(cuid())
  name   String
  code   String  @unique
  active Boolean @default(true)

  /// The fields below are collected at self-service registration
  /// (app/institution/register) — see lib/institution/register-institution.ts.
  /// All optional since the one seed-created demo institution predates
  /// this form and existing rows have none of them set.
  institutionType      InstitutionType?
  institutionTypeOther String?
  organizationName     String?
  address              String?
  contactName          String?
  contactTitle         String?
  contactEmail         String?
  contactPhone         String?
  estimatedPopulation  Int?
  estimatedUsers       Int?

  facilities     Facility[]
  users          User[]
  intakeSessions IntakeSession[]
  roadmaps       ResearchRoadmap[]
  auditLogs      AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model Facility {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  name   String
  code   String
  active Boolean @default(true)

  users          User[]
  intakeSessions IntakeSession[]
  auditLogs      AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, code])
  @@index([institutionId])
}

/// The application-owned authorization record for a Clerk identity.
/// `clerkUserId` is the only link to the authentication provider — no
/// credential material is ever duplicated here.
model User {
  id          String @id @default(cuid())
  clerkUserId String @unique

  role          UserRole
  accountStatus AccountStatus @default(ACTIVE)

  displayName        String?
  username           String? @unique
  internalIdentifier String?
  firstName          String?
  lastName           String?
  /// DOC number / inmate ID — a facility-assigned identifier, distinct
  /// from internalIdentifier (which predates this field and stays
  /// generic for non-incarcerated institution-managed roles).
  docNumber          String?
  /// Optional today; kept as a plain field (not a Housing Unit model) so
  /// filtering by it is possible now without over-building a feature no
  /// institution has asked to manage yet — see lib/institution/list-users.ts.
  housingUnit        String?

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  facilityId    String?
  facility      Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  mustChangePassword         Boolean   @default(false)
  temporaryPasswordExpiresAt DateTime?
  passwordChangedAt          DateTime?
  lastLoginAt                DateTime?

  /// Non-sensitive UI/session preferences only (e.g. reduced motion, local
  /// persistence opt-in when institution policy allows it). Never an
  /// authorization control — see lib/auth/authorization.ts for that.
  preferences Json?

  createdById  String?
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreatedBy")

  matters           Matter[]
  intakeSessions    IntakeSession[]
  roadmaps          ResearchRoadmap[]
  roadmapProgress   RoadmapProgress[]
  savedResources    SavedResource[]
  savedCases        SavedCase[]
  activity          UserActivity[]
  auditLogsAsActor  AuditLog[]        @relation("AuditActor")
  auditLogsAsTarget AuditLog[]        @relation("AuditTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
  @@index([facilityId])
  @@index([role])
  @@index([accountStatus])
  @@index([housingUnit])
}

/// A single legal matter belonging to one user — the unit that intakes,
/// roadmaps, and saved items are grouped under, so a user can research
/// more than one legal issue at once without the data mixing together.
/// `userId` is required (unlike IntakeSession/ResearchRoadmap) because a
/// Matter can only ever be created by an authenticated user — see
/// docs/behavior/matters.md.
model Matter {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// User-chosen or auto-generated (see lib/matters/matter-title.ts) —
  /// never left blank in the UI.
  title        String
  caseNumber   String?
  court        String?
  jurisdiction String?
  /// Short, denormalized description of the legal issue/case type, shown
  /// on the matter card — derived from the intake, not independently
  /// editable.
  matterType   String?
  status       MatterStatus @default(ACTIVE)

  intakeSessions IntakeSession[]
  roadmaps       ResearchRoadmap[]
  savedResources SavedResource[]
  savedCases     SavedCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model IntakeSession {
  id            String       @id @default(cuid())
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Optional — a guest (never-authenticated) intake session has no
  /// matter at all, mirroring the guest `userId: null` path; a matter is
  /// created only once the caller is authenticated.
  matterId      String?
  matter        Matter?      @relation(fields: [matterId], references: [id], onDelete: SetNull)
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  facilityId    String?
  facility      Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  status          IntakeStatus @default(DRAFT)
  caseType        String
  jurisdiction    String
  proceduralStage String
  researchGoals   Json
  documentTypes   Json

  /// AI-maintained running summary of facts gathered so far — never a raw
  /// transcript. See lib/ai/prompts/build-intake-interview-input.ts.
  factualSummary        String @default("")
  /// string[] of open factual gaps the AI has flagged but not yet resolved.
  unresolvedInformation Json   @default("[]")
  /// string[] of topic labels already covered, so the interviewer doesn't
  /// repeat questions.
  topicsCovered         Json   @default("[]")
  /// Number of adaptive (Layer 2) questions asked so far — enforced against
  /// INTAKE_MAX_AI_QUESTIONS server-side; the model cannot override this.
  questionCount         Int    @default(0)
  /// The currently pending, not-yet-answered IntakeQuestion (see
  /// types/intake-interview.ts), or null when none is pending (draft,
  /// ready-for-review, completed, abandoned). /answer validates its
  /// questionId against this before accepting an answer.
  currentQuestion       Json?

  answers  IntakeAnswer[]
  roadmaps ResearchRoadmap[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([institutionId])
  @@index([facilityId])
}

/// One row per adaptive-interview question/answer turn, in order.
model IntakeAnswer {
  id              String        @id @default(cuid())
  intakeSessionId String
  intakeSession   IntakeSession @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)

  questionId   String
  questionText String
  answerText   String
  answerType   String
  sequence     Int

  createdAt DateTime @default(now())

  @@unique([intakeSessionId, sequence])
  @@index([intakeSessionId])
}

model ResearchRoadmap {
  id              String         @id @default(cuid())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Optional for the same reason as IntakeSession.matterId — a guest
  /// roadmap (if one ever existed) would have none.
  matterId        String?
  matter          Matter?        @relation(fields: [matterId], references: [id], onDelete: SetNull)
  intakeSessionId String?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: SetNull)
  institutionId   String?
  institution     Institution?   @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  title      String
  summary    String
  sourceKind RoadmapSourceKind
  /// Full structured ResearchRoadmap payload (see types/roadmap.ts) — never
  /// raw case narrative beyond what the user already submitted in the
  /// linked IntakeSession. Each step within `content.steps` has a stable
  /// `id` that RoadmapProgress.stepId references.
  content    Json

  progress   RoadmapProgress[]
  savedCases SavedCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([matterId])
  @@index([institutionId])
}

/// Per-user, per-step progress on a roadmap. Never modifies the original
/// roadmap content (`ResearchRoadmap.content`) — this is tracking data
/// layered on top of it.
model RoadmapProgress {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapId String
  roadmap   ResearchRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  stepId String
  status RoadmapStepStatus @default(NOT_STARTED)
  /// Private note, visible only to the owning user — never rendered
  /// anywhere else and never included in activity/audit metadata.
  note   String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roadmapId, stepId])
  @@index([userId, roadmapId])
}

/// User-owned saved items (resources, glossary terms, roadmap steps,
/// source suggestions, notes). Duplicate saves are prevented by the
/// unique constraint, not just application logic.
model SavedResource {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Set when this save happened within a specific matter's roadmap
  /// (e.g. ROADMAP_STEP, NOTE) — left null for saves made outside any
  /// matter context (e.g. a glossary term saved from the general
  /// Resources pages), which stay account-wide rather than per-matter.
  matterId     String?
  matter       Matter?           @relation(fields: [matterId], references: [id], onDelete: SetNull)
  resourceType SavedResourceType
  /// Stable identifier within resourceType (e.g. a resource slug, a
  /// glossary term name, a roadmap step id) — what the uniqueness
  /// constraint is scoped by.
  resourceKey  String
  title        String
  /// Validated/sanitized internal or verified external URL — see
  /// lib/saved/saved-resource-schema.ts.
  href         String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Global uniqueness for matter-less (account-wide) saves.
  @@unique([userId, resourceType, resourceKey])
  /// Per-matter uniqueness — the same resource can be saved once per
  /// matter without colliding with a save in a different matter.
  @@unique([matterId, resourceType, resourceKey])
  @@index([userId, createdAt])
  @@index([matterId])
}

/// A verified case a user has chosen to keep, retrieved through a real
/// legal source provider (see lib/case-search/) — never an AI-invented
/// summary without the underlying source record. `roadmapId` is optional
/// since a case may be saved from a standalone search not tied to any
/// one roadmap. The unique constraint prevents saving the same
/// provider's case twice.
model SavedCase {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Set when saved from within a specific matter's roadmap/case search;
  /// left null for a standalone save not tied to any matter. The same
  /// case can be saved once per matter (see the matterId unique
  /// constraint below) — it may legitimately be relevant to more than
  /// one of a user's matters.
  matterId String?
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)

  roadmapId String?
  roadmap   ResearchRoadmap? @relation(fields: [roadmapId], references: [id], onDelete: SetNull)

  /// Which CaseSourceProvider retrieved this record (e.g. "courtlistener") — see lib/case-search/types.ts.
  providerName   String
  providerCaseId String

  caseName     String
  citation     String?
  court        String
  jurisdiction String
  decisionDate DateTime?
  docketNumber String?
  sourceUrl    String
  sourceName   String
  /// The roadmap research topic this case was matched against, if saved from a roadmap-scoped search.
  matchedTopic String?
  /// Private note, visible only to the owning user.
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, providerName, providerCaseId])
  @@unique([matterId, providerName, providerCaseId])
  @@index([userId, createdAt])
  @@index([roadmapId])
  @@index([matterId])
}

/// Every legal-case provider this app knows about — only COURTLISTENER is
/// active. The rest are documented future adapters (see
/// docs/behavior/verified-case-search.md's provider architecture
/// section) — no code ever calls them.
enum LegalCaseProvider {
  COURTLISTENER
  VLEX
  FASTCASE
  WESTLAW
  LEXIS
}

/// Mirrors lib/case-search/types.ts's CaseVerificationStatus — a case is
/// never simply "verified" or not. See that file for what each value means.
enum LegalCaseVerificationStatus {
  VERIFIED
  POSSIBLE_MATCH
  NOT_VERIFIED
  SOURCE_UNAVAILABLE
}

/// Normalized, persisted record of a case retrieved from a verified legal
/// source provider — the durable counterpart to lib/case-search/cache.ts's
/// in-memory search cache. Written when a case is opened in detail (not on
/// every search hit, which would be wasteful), so citation-verification
/// results and quote provenance have a stable place to live across
/// requests and server restarts. Never stores AI-generated content — see
/// CaseExplanationRecord, always a separate row/table, so source and
/// AI-generated content can never be accidentally conflated.
model LegalCaseRecord {
  id             String            @id @default(cuid())
  provider       LegalCaseProvider
  providerCaseId String
  clusterId      String?

  caseName     String
  citation     String?
  /// Every reporter citation the provider returned, not just the primary one — string[].
  citations    Json
  courtName    String?
  courtId      String?
  jurisdiction String?
  docketNumber String?
  decisionDate DateTime?
  /// Full opinion text when the provider made it available — never fabricated, may be null.
  opinionText  String?
  sourceUrl    String?

  verificationStatus LegalCaseVerificationStatus
  /// How the status was established (e.g. "citation-lookup", "id-lookup") — never claim a verification method that wasn't actually used.
  verificationMethod String?
  /// Set only when the provider's own metadata identifies this record as originally digitized by the Caselaw Access Project.
  originalCollection String?

  retrievedAt DateTime @default(now())
  /// The raw provider response, kept for audit/debugging — never read directly by the UI, which only ever sees the normalized fields above.
  rawSourceMetadata Json?

  explanations CaseExplanationRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerCaseId])
  @@index([citation])
}

/// AI-generated educational content about a LegalCaseRecord — always a
/// separate table from the source opinion, so it is structurally
/// impossible to display AI-generated text as part of the original
/// opinion. sourceTextHash lets a cached explanation be invalidated if
/// the underlying opinion text ever changes (e.g. becomes available
/// after previously being null).
model CaseExplanationRecord {
  id          String          @id @default(cuid())
  legalCaseId String
  legalCase   LegalCaseRecord @relation(fields: [legalCaseId], references: [id], onDelete: Cascade)

  model          String
  promptVersion  String
  sourceTextHash String

  summary           String
  /// string[]
  keyFacts          Json
  /// string[]
  legalIssues       Json
  holding           String
  courtsReasoning   String
  ruleOfLaw         String
  whyThisCaseMatters String
  howItMightRelate  String
  /// ImportantQuote[] — { quote, whyItMatters, location? }, each independently re-verified against opinionText before storage.
  importantQuotes   Json
  /// CaseKeyTerm[] — { term, definition }
  keyTerms          Json
  basedOnFullOpinionText Boolean

  generatedAt DateTime @default(now())

  @@index([legalCaseId])
  @@index([sourceTextHash])
}

/// Safe, UI-facing activity history — see docs/behavior/user-dashboard.md
/// and lib/activity/approved-activity-events.ts. Never full narrative
/// text, prompts, or secrets; distinct from AuditLog (security/ops
/// history).
model UserActivity {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        UserActivityType
  title       String
  description String?
  href        String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// Structured security/administrative audit trail. Never store secrets,
/// password material, or full case narratives here — see
/// docs/behavior/audit-events.md and lib/security/audit-log.ts, which
/// enforces an allowlist of metadata keys before a row is written.
model AuditLog {
  id String @id @default(cuid())

  actorUserId String?
  actorUser   User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  targetUserId String?
  targetUser   User?   @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  facilityId    String?
  facility      Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  action   String
  outcome  AuditOutcome
  metadata Json?

  createdAt DateTime @default(now())

  @@index([institutionId])
  @@index([action])
  @@index([createdAt])
  @@index([actorUserId])
  @@index([targetUserId])
}
